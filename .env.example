# Optional — these override CLI defaults at runtime.

# URL of the NestJS orchestrator API
DEPIN_ORCHESTRATOR_URL=http://localhost:3000

# URL of the web frontend (used by the setup wizard to show the token page link)
# Defaults to DEPIN_ORCHESTRATOR_URL if not set
DEPIN_WEB_URL=http://localhost:3001

DEPIN_MODEL_CACHE_DIR=~/.cache/huggingface/hub

# CUDA visibility — restrict to specific GPU index
CUDA_VISIBLE_DEVICES=0

HF_TOKEN=
